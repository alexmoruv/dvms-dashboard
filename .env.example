# Gigachat API (Сбер) — https://lk.sber.ru/
# Получить: Компании → API → Gigachat → скопировать API ключ
VITE_GIGACHAT_API_KEY=your_gigachat_api_key_here

# Tavily Search API (опционально, для веб-поиска мероприятий)
# Если не используете веб-поиск, может быть dummy-значением
# Получить: https://app.tavily.com (1000 запросов/месяц бесплатно)
VITE_TAVILY_API_KEY=tvly-your_key_here_or_dummy

